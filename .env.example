# ============================================================
#  FalconVR Backend — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# MongoDB connection string
# For local MongoDB:  mongodb://localhost:27017/falconvr
# For MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/falconvr
MONGO_URI=mongodb://localhost:27017/falconvr

# JWT Secret — use any long random string, keep it secret!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT token expiry (e.g. 7d = 7 days, 24h = 24 hours)
JWT_EXPIRES_IN=7d

# Port the server runs on
PORT=5000
